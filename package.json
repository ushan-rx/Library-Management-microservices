{
  "name": "library-system-microservices",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:api-gateway": "nest build api-gateway",
    "build:auth-service": "nest build auth-service",
    "build:member-service": "nest build member-service",
    "build:category-service": "nest build category-service",
    "build:book-service": "nest build book-service",
    "build:borrow-service": "nest build borrow-service",
    "build:fine-payment-service": "nest build fine-payment-service",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start api-gateway",
    "start:auth-service": "nest start auth-service",
    "start:member-service": "nest start member-service",
    "start:book-service": "nest start book-service",
    "start:borrow-service": "nest start borrow-service",
    "start:category-service": "nest start category-service",
    "start:fine-payment-service": "nest start fine-payment-service",
    "start:dev": "nest start api-gateway --watch",
    "start:debug": "nest start api-gateway --debug --watch",
    "start:prod": "node dist/apps/api-gateway/main",
    "docker:up": "docker compose up -d postgres-core",
    "docker:up:all": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs:postgres": "docker compose logs postgres-core",
    "docker:logs:all": "docker compose logs -f",
    "docker:build:api-gateway": "docker build -f apps/api-gateway/Dockerfile -t library-system/api-gateway:local .",
    "docker:build:auth-service": "docker build -f apps/auth-service/Dockerfile -t library-system/auth-service:local .",
    "docker:build:member-service": "docker build -f apps/member-service/Dockerfile -t library-system/member-service:local .",
    "docker:build:category-service": "docker build -f apps/category-service/Dockerfile -t library-system/category-service:local .",
    "docker:build:book-service": "docker build -f apps/book-service/Dockerfile -t library-system/book-service:local .",
    "docker:build:borrow-service": "docker build -f apps/borrow-service/Dockerfile -t library-system/borrow-service:local .",
    "docker:build:fine-payment-service": "docker build -f apps/fine-payment-service/Dockerfile -t library-system/fine-payment-service:local .",
    "prisma:validate:auth-service": "prisma validate --schema apps/auth-service/prisma/schema.prisma",
    "prisma:validate:member-service": "prisma validate --schema apps/member-service/prisma/schema.prisma",
    "prisma:validate:category-service": "prisma validate --schema apps/category-service/prisma/schema.prisma",
    "prisma:validate:book-service": "prisma validate --schema apps/book-service/prisma/schema.prisma",
    "prisma:validate:borrow-service": "prisma validate --schema apps/borrow-service/prisma/schema.prisma",
    "prisma:validate:fine-payment-service": "prisma validate --schema apps/fine-payment-service/prisma/schema.prisma",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --runInBand --config ./apps/api-gateway/test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^6.16.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.3.1",
    "prisma": "^6.16.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/test/"
    ]
  }
}
