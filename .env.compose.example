# Compose-oriented environment example
NODE_ENV=production
LOG_LEVEL=info

POSTGRES_HOST=postgres-core
POSTGRES_PORT=5432
POSTGRES_USER=library_admin
POSTGRES_PASSWORD=library_password
POSTGRES_SUPER_DB=postgres

API_GATEWAY_PORT=3000
API_GATEWAY_SERVICE_NAME=api-gateway
JWT_SECRET=change-me-in-compose-env
JWT_EXPIRES_IN=1h
CORS_ALLOWED_ORIGINS=http://localhost:3000

AUTH_SERVICE_PORT=3001
AUTH_SERVICE_NAME=auth-service
AUTH_DATABASE_URL=postgresql://library_admin:library_password@postgres-core:5432/auth_db?schema=public
AUTH_SERVICE_BASE_URL=http://auth-service:3001
AUTH_STORAGE_DRIVER=prisma

MEMBER_SERVICE_PORT=3002
MEMBER_SERVICE_NAME=member-service
MEMBER_DATABASE_URL=postgresql://library_admin:library_password@postgres-core:5432/member_db?schema=public
MEMBER_SERVICE_BASE_URL=http://member-service:3002
MEMBER_STORAGE_DRIVER=prisma

BOOK_SERVICE_PORT=3003
BOOK_SERVICE_NAME=book-service
BOOK_DATABASE_URL=postgresql://library_admin:library_password@postgres-core:5432/book_db?schema=public
BOOK_SERVICE_BASE_URL=http://book-service:3003
BOOK_STORAGE_DRIVER=prisma
BOOK_VALIDATE_CATEGORY_ON_WRITE=true

CATEGORY_SERVICE_PORT=3004
CATEGORY_SERVICE_NAME=category-service
CATEGORY_DATABASE_URL=postgresql://library_admin:library_password@postgres-core:5432/category_db?schema=public
CATEGORY_SERVICE_BASE_URL=http://category-service:3004
CATEGORY_STORAGE_DRIVER=prisma

BORROW_SERVICE_PORT=3005
BORROW_SERVICE_NAME=borrow-service
BORROW_DATABASE_URL=postgresql://library_admin:library_password@postgres-core:5432/borrow_db?schema=public
BORROW_SERVICE_BASE_URL=http://borrow-service:3005
BORROW_STORAGE_DRIVER=prisma
BORROW_FINE_AMOUNT_PER_DAY=100

FINE_PAYMENT_SERVICE_PORT=3006
FINE_PAYMENT_SERVICE_NAME=fine-payment-service
FINE_DATABASE_URL=postgresql://library_admin:library_password@postgres-core:5432/fine_db?schema=public
FINE_PAYMENT_SERVICE_BASE_URL=http://fine-payment-service:3006
FINE_STORAGE_DRIVER=prisma

# Optional file-backed values
# JWT_SECRET_FILE=./secrets/jwt_secret.txt
# AUTH_DATABASE_URL_FILE=./secrets/auth_database_url.txt
# MEMBER_DATABASE_URL_FILE=./secrets/member_database_url.txt
# CATEGORY_DATABASE_URL_FILE=./secrets/category_database_url.txt
# BOOK_DATABASE_URL_FILE=./secrets/book_database_url.txt
# BORROW_DATABASE_URL_FILE=./secrets/borrow_database_url.txt
# FINE_DATABASE_URL_FILE=./secrets/fine_database_url.txt
